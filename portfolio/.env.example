# ─────────────────────────────────────────────────────────────
# SERVER-ONLY secrets (NO "VITE_" prefix → never shipped to the browser).
# Set these in the Vercel dashboard (Project → Settings → Environment Variables)
# and in a local .env for `vercel dev`.
# ─────────────────────────────────────────────────────────────

# Admin panel password (used by /api/login)
ADMIN_PASSWORD=

# GitHub Personal Access Token with "contents:write" on the portfolio repo.
# Used server-side by /api/commit, /api/upload, /api/repo(s). Never exposed.
GITHUB_PAT=

# Target repo for commits, e.g. "ndmthuan97/ndmthuan97"
# Also pins which owner's repos the admin may read (read endpoints reject other owners).
GITHUB_REPO=

# REQUIRED: random string to sign session tokens. Login fails (500) if unset.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Optional AI providers for the "Generate with AI" button (used by /api/ai).
# Provide at least one to enable AI; if both are set, Groq is tried first then Gemini.
# (Models are fixed in code: Groq llama-3.3-70b-versatile, Gemini gemini-2.0-flash.)
GROQ_API_KEY=
GEMINI_API_KEY=
